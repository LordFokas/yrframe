{
	"compilerOptions": {
		"declaration": true,
		"esModuleInterop": true,
		"moduleResolution": "NodeNext",
		"module": "NodeNext",
		"target": "ESNext",
		"useDefineForClassFields": true,
		

		"noImplicitAny": true,
		"allowJs": true,

		"jsx": "react",
		"jsxFactory": "ComponentFactory.make",

		"rootDir": "src",
		"outDir": "dist"
	},
	"include": ["src/*"]
}